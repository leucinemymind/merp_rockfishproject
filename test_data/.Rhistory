quad_model <- lm(difference ~ logP + I(logP^2), data = inhibition_data_normal)
summary(quad_model)
ggplot(inhibition_data_normal, aes(x = logP, y = difference)) +
geom_point() + geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +
labs(title = "LogP vs Difference in Affinity",
x = "LogP",
y = "Difference in Affinity (1ITB - 3O4O)") +
theme_minimal()
ggplot(inhibition_data_normal, aes(x = logP, y = difference)) +
geom_point() + geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +
labs(title = "LogP vs Difference in Affinity",
x = "LogP",
y = "Difference in Affinity (1ITB - 3O4O)") +
theme_minimal()
quad_model <- lm(difference ~ logP + I(logP^2), data = inhibition_data_normal)
summary(quad_model)
ggplot(inhibition_data_normal, aes(x = logP, y = difference)) +
geom_point() +
geom_smooth(method = "lm", formula = y ~ x, linetype = "dashed") +   # linear regression
geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +               # quadratic regression
labs(title = "LogP vs Difference in Affinity",
x = "LogP",
y = "Difference in Affinity (1ITB - 3O4O)") +
theme_minimal()
#packages + data
# t-test
library(tidyverse)
inhibition_data_tidy <- read_csv("~/Dropbox/getcontacts/receptors_il1b/autodock/il1b_inhibition_data - Sheet1 (1).csv")
inhibition_data_normal <- read_csv("~/Dropbox/getcontacts/receptors_il1b/autodock/il1b_inhibition_data - Sheet1 (2).csv")
# diff
ggplot(inhibition_data_tidy, aes(x = protein, y = affinity)) +
geom_boxplot(fill = "skyblue") +
geom_jitter(width = 0.1, alpha = 0.5) +
labs(title = "Docking affinities of ligands across IL-1β receptors", x = "protein", y = "affinity (kcal/mol)") +
theme_minimal()
t.test(inhibition_data_normal$affinity_1ITB, inhibition_data_normal$affinity_3O4O, paired = TRUE)
# mono
ggplot(data = inhibition_data_normal, aes(x = logP, y = difference)) +
geom_point() +
labs(title = "LogP vs difference in affinity", x = "logP", y = "difference in affinity (1ITB - 3O4O) (kcal/mol)") +
theme_minimal()
cor.test(
inhibition_data_normal$logP,
inhibition_data_normal$difference,
method = "spearman",
exact = FALSE
)
# quad
quad_model <- lm(difference ~ logP + I(logP^2), data = inhibition_data_normal)
summary(quad_model)
ggplot(inhibition_data_normal, aes(x = logP, y = difference)) +
geom_point() +
geom_smooth(method = "lm", formula = y ~ x, linetype = "dashed") +   # linear regression
geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +               # quadratic regression
labs(title = "LogP vs Difference in Affinity",
x = "LogP",
y = "Difference in Affinity (1ITB - 3O4O)") +
theme_minimal()
ggplot(inhibition_data_normal, aes(x = logP, y = difference)) +
geom_point() +
geom_smooth(method = "lm", formula = y ~ x, color = "red", linetype = "dashed") +   # linear regression
geom_smooth(method = "lm", formula = y ~ x + I(x^2)) +               # quadratic regression
labs(title = "LogP vs Difference in Affinity",
x = "LogP",
y = "Difference in Affinity (1ITB - 3O4O)") +
theme_minimal()
